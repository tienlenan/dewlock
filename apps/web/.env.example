# Dewlock — Environment Variables Template
# Copy this to .env.local and fill in values.
# NEVER commit .env.local (it is gitignored).
# See LOCAL-ENV-KEYS.md at the repo root for actual values (also gitignored).

# =============================================================================
# SERVER-ONLY (no NEXT_PUBLIC_ prefix — never shipped to the browser bundle)
# =============================================================================

# LLM via Vercel AI Gateway (Gemini)
AI_GATEWAY_API_KEY=
AGENT_MODEL=google/gemini-2.5-flash

# Walrus Memory (memwal) — run scripts/provision-memwal.ts to generate
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz

# Walrus Blob writes — OPERATIONAL signer ONLY (blob receipts, never user funds)
WALRUS_SDK_WALLET_KEY=
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_UPLOAD_RELAY_DISABLED=false
WALRUS_UPLOAD_RELAY_TIP_MAX=10000000
WALRUS_BLOB_EPOCHS=12

# Sui networks
SUI_NETWORK=mainnet
# Server Sui JSON-RPC endpoint. The public fullnode rate-limits; a BlockVision FREE
# key works as a higher-limit RPC node here (the indexing API is Pro-only, RPC is free):
#   SUI_RPC_URL=https://sui-mainnet.blockvision.org/v1/<YOUR_BLOCKVISION_KEY>
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_GRAPHQL_URL=https://graphql.mainnet.sui.io/graphql
SUI_DEVNET_RPC_URL=https://fullnode.devnet.sui.io:443

# Guardian caps — SERVER-AUTHORITATIVE (the NEXT_PUBLIC_ copies below are display-only).
# Per-trade / per-day USD ceilings. Lower these to tighten; a too-low value (e.g. 5)
# refuses any normal swap on the cap gate. Match NEXT_PUBLIC_TX_USD_CAP for honest display.
TX_USD_CAP=100
DAILY_USD_CAP=500

# Conservative USD price FLOORS for the cap (used when the Pyth cache is cold or a feed
# is rejected). The Guardian uses max(livePyth, floor) so a glitch-low feed can only
# tighten the cap, never loosen it. ETH/BTC floors make WETH/wBTC swappable.
SUI_USD_PRICE_FLOOR=
DEEP_USD_PRICE_FLOOR=
WETH_USD_PRICE_FLOOR=
WBTC_USD_PRICE_FLOOR=

# Dewlock receipt anchor contract (move/dewlock_receipt). Both are required to anchor
# HEADs on-chain; unset → the receipt blob still writes, anchor degrades to not_configured.
# CONFIG_ID is the shared Config object created at publish (first arg of create_head/set_head).
DEWLOCK_RECEIPT_PACKAGE_ID=
DEWLOCK_RECEIPT_CONFIG_ID=

# =============================================================================
# PUBLIC (client-visible — no secrets)
# =============================================================================

NEXT_PUBLIC_SUI_NETWORK=mainnet
# Client-visible Sui RPC for the Wormhole Connect bridge widget. The public
# fullnode rate-limits ("Throttled" responses → JSON parse error in Connect);
# set a dedicated provider (Ankr/BlockVision/Triton/etc.) to avoid it.
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
NEXT_PUBLIC_AGENT_URL=/api/agent
NEXT_PUBLIC_EXPLORER_OBJECT_URL_TEMPLATE=https://suiscan.xyz/{network}/object/{id}
# Transaction explorer link (receipt "tx digest"). Optional — if unset, derived from
# the object template by swapping /object/ → /tx/. {network} and {digest} are substituted.
NEXT_PUBLIC_EXPLORER_TX_URL_TEMPLATE=https://suiscan.xyz/{network}/tx/{digest}
NEXT_PUBLIC_FEATURE_CONFIDENTIAL=false
NEXT_PUBLIC_TX_USD_CAP=50
NEXT_PUBLIC_DEMO_MODE=live

# SuiVision (BlockVision) API key — server-only; powers verified-token assets list (price/logo/usdValue)
# and the dashboard's per-wallet on-chain footprint (account coins + activities). Account endpoints are
# Pro-tier + trial-limited, so the client caches aggressively and fails soft (degraded state) when absent.
BLOCKVISION_API_KEY=
# Blockberry API key — server-only; FREE-tier fallback for the enriched portfolio
# (verified flag + logo + price) when the BlockVision indexing API is Pro-gated.
# Cascade: BlockVision indexing → Blockberry → plain RPC. Get a key at blockberry.one.
BLOCKBERRY_API_KEY=
# BlockVision API base (optional; defaults to https://api.blockvision.org/v2)
BLOCKVISION_BASE_URL=

# CORS allow-list for the read-only JSON GET routes (/api/protocols, /api/metrics, /api/user-stats,
# /api/memory-recall). Comma-separated origins; when unset, same-origin GETs work and cross-origin is
# reflected (permissive default for public read-only data). Set in production to lock origins down.
ALLOWED_ORIGINS=
